# Clerk — enable Organizations in Dashboard: https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding
# Tilgangskontroll (se docs/PAYWALL_AND_ACCESS.md): invite-only = steng sign-up + kun tillatte brukere inn
# NEXT_PUBLIC_SIGNUP_MODE=invite-only
# ALLOWED_CLERK_USER_IDS=user_xxx,user_yyy   (Clerk user IDs fra Dashboard → Users; kun nødvendig når SIGNUP_MODE=invite-only)
# Clerk Webhooks (user.deleted → data cleanup / GDPR)
# Signing secret from Clerk Dashboard → Webhooks → endpoint → Signing Secret
CLERK_WEBHOOK_SIGNING_SECRET=whsec_...
# Nyere Clerk: bruk disse i stedet for AFTER_SIGN_IN/UP ved behov
# NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
# NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# Supabase (Postgres + Storage)
# Bruk SEPARAT database for lokal utvikling og for produksjon (aldri samme DB).
# Lokal: .env.local med DATABASE_URL til "project opus" (eller eget dev-prosjekt).
# Prod: Vercel env peker på eget Supabase-prosjekt (f.eks. "Revizo prod"). Se docs/DATABASE_DEV_PROD.md.
DATABASE_URL=postgresql://postgres:[PASSWORD]@[HOST]:6543/postgres              # Transaction Pooler (port 6543) — for app
DATABASE_MIGRATION_URL=postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres    # Session Pooler (port 5432) — for migrasjoner/studio
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_SERVICE_ROLE_KEY=...

# Resend (email notifications)
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_ADDRESS=Revizo <noreply@accountcontrol.no>
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron (Vercel Cron job authorization)
CRON_SECRET=your_cron_secret_here

# Environment (used for visual badge in non-prod environments)
# Set to "development" or "staging" locally/on staging; leave unset (or "production") in Vercel prod.
NEXT_PUBLIC_ENV=development

# Encryption (AES-256-GCM for secrets at rest, e.g. Tripletex tokens)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your_64_hex_char_key_here

# System admin access (comma-separated)
ADMIN_EMAILS=admin@example.com
ADMIN_DOMAINS=revizo.no

# Sentry (error tracking)
NEXT_PUBLIC_SENTRY_DSN=https://...@....ingest.sentry.io/...
SENTRY_DSN=https://...@....ingest.sentry.io/...
SENTRY_ORG=your-org
SENTRY_PROJECT=account-control
SENTRY_AUTH_TOKEN=sntrys_...

# AI (Revizo AI-assistent)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Tripletex API
# Test: https://api-test.tripletex.tech/v2 | Prod: https://tripletex.no/v2
TRIPLETEX_API_BASE_URL=https://api-test.tripletex.tech/v2
TRIPLETEX_CONSUMER_TOKEN=...
TRIPLETEX_EMPLOYEE_TOKEN=...

# Visma Business NXT (OAuth 2.0 + GraphQL)
VISMA_CLIENT_ID=your_visma_client_id
VISMA_CLIENT_SECRET=your_visma_client_secret
VISMA_REDIRECT_URI=http://localhost:3000/api/auth/visma-nxt/callback
VISMA_WEBHOOK_SECRET=your_webhook_signing_secret

# Stripe (postponed — not currently in use)
# STRIPE_SECRET_KEY=sk_test_...

# Worker (Revizo Agent background jobs)
WORKER_CONCURRENCY=3
WORKER_POLL_INTERVAL_MS=30000
